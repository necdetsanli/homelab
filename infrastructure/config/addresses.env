# =============================================================================
# Homelab IP Address Map -- Single source of truth
# =============================================================================
# Central reference for all IP assignments used across this repository.
# Configuration files hardcode these values because each tool (HAProxy,
# Keepalived, Cilium, shell scripts) needs native formats -- there is no
# shared templating layer.  Update this file first, then grep for the old
# IP to find every place that needs patching.
#
# Quick search:  grep -rn '192.168.20.22' --include='*.yaml' --include='*.cfg' --include='*.sh'
# =============================================================================

# ── Edge Tier (VLAN 20 -- 192.168.20.0/24) ──────────────────────────────────

EDGE1_IP=192.168.20.20          # edge-1 (HAProxy + Keepalived MASTER)
EDGE2_IP=192.168.20.21          # edge-2 (HAProxy + Keepalived BACKUP)
VIP_IP=192.168.20.22            # Keepalived VRRP VIP (HAProxy frontend)

# ── Vault Cluster ────────────────────────────────────────────────────────────

VAULT1_IP=192.168.20.25         # vault-1
VAULT2_IP=192.168.20.26         # vault-2
VAULT3_IP=192.168.20.27         # vault-3

# ── Kubernetes Cluster (RKE2) ────────────────────────────────────────────────

K8S_MASTER_IP=192.168.20.30     # k8s-master-1 (control plane)
K8S_POD_CIDR=10.42.0.0/16      # Cilium pod CIDR
K8S_SVC_CIDR=10.43.0.0/16      # Kubernetes service CIDR

# ── Cilium LB-IPAM ──────────────────────────────────────────────────────────

ARGOCD_LB_IP=192.168.20.200    # ArgoCD server LoadBalancer VIP
GATEWAY_LB_IP=192.168.20.201   # Cilium Gateway API (Envoy) VIP
LOKI_PUSH_LB_IP=192.168.20.202 # Loki push endpoint (bare-metal Alloy)
MIMIR_PUSH_LB_IP=192.168.20.203 # Mimir push endpoint (bare-metal Alloy)
ZABBIX_SERVER_LB_IP=192.168.20.204 # Zabbix Server trapper (bare-metal Agent 2)
LB_POOL_START=192.168.20.200   # CiliumLoadBalancerIPPool start
LB_POOL_STOP=192.168.20.250    # CiliumLoadBalancerIPPool end

# ── Infrastructure Services (VLAN 20) ───────────────────────────────────────

UNIFI_IP=192.168.20.10          # UniFi controller
TRUENAS_IP=192.168.20.50        # TrueNAS (NFS, backups)
NEXTCLOUD_IP=192.168.20.51      # Nextcloud
ADGUARD_IP=192.168.20.53        # AdGuard Home DNS
RANCHER_IP=192.168.20.60        # Rancher management

# ── Management VLAN (VLAN 50 -- 192.168.50.0/24) ────────────────────────────

OPNSENSE_MGMT_IP=192.168.50.1  # OPNsense (mgmt interface)
WAZUH_IP=192.168.50.4           # Wazuh SIEM
FREEIPA_IP=192.168.50.5         # FreeIPA (DNS, Kerberos, LDAP)
PROXMOX_IP=192.168.50.10        # Proxmox VE
ILO_IP=192.168.50.20            # HP iLO

# ── BGP ──────────────────────────────────────────────────────────────────────

OPNSENSE_BGP_IP=192.168.20.1   # OPNsense BGP peer (AS 64500)
K8S_BGP_ASN=64501               # Kubernetes cluster AS number
OPNSENSE_BGP_ASN=64500          # OPNsense AS number

# ── Other ────────────────────────────────────────────────────────────────────

WG_ADMIN_IP=10.66.66.2          # WireGuard admin tunnel endpoint
ME30_IP=192.168.30.20           # ME30 device (IoT VLAN 30)
