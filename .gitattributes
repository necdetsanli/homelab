# --------------------------------------------------------
# Line-ending normalisation — enforce LF everywhere
# --------------------------------------------------------
# `text=auto` lets Git detect text vs. binary.
# `eol=lf`   forces LF in the working tree on ALL platforms,
#             so files on Linux edge nodes never contain \r\n.
* text=auto eol=lf

# ---- Explicitly mark text file types ----
*.yaml       text eol=lf
*.yml        text eol=lf
*.json       text eol=lf
*.toml       text eol=lf
*.hcl        text eol=lf
*.tf         text eol=lf
*.sh         text eol=lf
*.bash       text eol=lf
*.py         text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.cfg        text eol=lf
*.conf       text eol=lf
*.ctmpl      text eol=lf
*.service    text eol=lf
*.timer      text eol=lf
*.env        text eol=lf
*.gitignore  text eol=lf
*.gitattributes text eol=lf
*.editorconfig  text eol=lf
CODEOWNERS   text eol=lf
Makefile     text eol=lf
Dockerfile   text eol=lf
LICENSE      text eol=lf

# ---- Binary — never touch these ----
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.gz   binary
*.tar  binary
*.zip  binary
*.der  binary
*.p12  binary
*.pfx  binary

# ---- Large vendored manifests (still text, still LF) ----
vendor/**/*.yaml text eol=lf
